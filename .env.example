# ── AI Providers ──────────────────────────────────────────────────────────
# Primary provider. If unset/invalid/quota-exceeded, HeritageHop falls back
# to OpenRouter, then Groq, then a bundled mock provider (always available).
GEMINI_API_KEY=

# Optional fallback providers
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ── Supabase (optional persistence) ──────────────────────────────────────
# HeritageHop works fully without these — local seed data is used instead.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Admin demo route ──────────────────────────────────────────────────────
# Password for the /admin mock login. Never reuse a real credential here.
ADMIN_DEMO_PASSWORD=heritage-demo-2026

# ── Optional real events data ────────────────────────────────────────────
TICKETMASTER_API_KEY=
